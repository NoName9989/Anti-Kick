-- =============================================
-- 🔥 ANTI KICK AFK (DÀNH RIÊNG CHO MOBILE)
-- Không có gì liên quan đến stage cả
-- Chỉ anti kick thuần, siêu nhẹ, ổn định
-- =============================================

local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer

local antiKickEnabled = true
local antiConnection = nil

-- ==================== TẠO GUI NHỎ DÀNH CHO MOBILE ====================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AntiKickMobile"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 280, 0, 120)
mainFrame.Position = UDim2.new(1, -290, 0, 10)  -- góc trên bên phải, nhỏ gọn
mainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
mainFrame.BorderSizePixel = 0
mainFrame.BackgroundTransparency = 0.1
mainFrame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 14)
corner.Parent = mainFrame

-- Title
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 35)
title.BackgroundTransparency = 1
title.Text = "🛡️ ANTI KICK AFK"
title.TextColor3 = Color3.fromRGB(0, 255, 120)
title.TextScaled = true
title.Font = Enum.Font.GothamBold
title.Parent = mainFrame

-- Nút Bật/Tắt (to, dễ bấm trên mobile)
local toggleButton = Instance.new("TextButton")
toggleButton.Size = UDim2.new(0.9, 0, 0, 55)
toggleButton.Position = UDim2.new(0.05, 0, 0, 45)
toggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
toggleButton.Text = "ANTI KICK: BẬT"
toggleButton.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleButton.TextScaled = true
toggleButton.Font = Enum.Font.GothamBold
toggleButton.Parent = mainFrame

local btnCorner = Instance.new("UICorner")
btnCorner.CornerRadius = UDim.new(0, 12)
btnCorner.Parent = toggleButton

-- Status nhỏ
local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, 0, 0, 20)
statusLabel.Position = UDim2.new(0, 0, 1, -25)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = "Đang hoạt động - AFK thoải mái"
statusLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
statusLabel.TextScaled = true
statusLabel.Font = Enum.Font.Gotham
statusLabel.Parent = mainFrame

-- ==================== HÀM ANTI KICK ====================
local function startAntiKick()
	if antiConnection then return end
	
	antiConnection = player.Idled:Connect(function()
		if not antiKickEnabled then return end
		
		VirtualUser:CaptureController()
		VirtualUser:ClickButton2(Vector2.new(0, 0))
		
		-- Có thể bỏ comment dòng dưới nếu muốn xem thông báo mỗi lần kích hoạt
		-- print("🛡️ Anti-Kick kích hoạt (AFK ~20 giây)")
	end)
end

local function stopAntiKick()
	if antiConnection then
		antiConnection:Disconnect()
		antiConnection = nil
	end
end

-- ==================== NÚT TOGGLE ====================
toggleButton.MouseButton1Click:Connect(function()
	antiKickEnabled = not antiKickEnabled
	
	if antiKickEnabled then
		toggleButton.Text = "ANTI KICK: BẬT"
		toggleButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
		statusLabel.Text = "Đang hoạt động - AFK thoải mái"
		statusLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
		startAntiKick()
	else
		toggleButton.Text = "ANTI KICK: TẮT"
		toggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
		statusLabel.Text = "Đã tắt anti kick"
		statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
		stopAntiKick()
	end
end)

-- ==================== KHỞI ĐỘNG ====================
startAntiKick()   -- Tự động bật ngay khi script chạy

print("✅ Anti Kick AFK (Mobile) đã load thành công!")
print("Menu nhỏ góc trên bên phải - bấm nút để bật/tắt")
